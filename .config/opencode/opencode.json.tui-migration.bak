{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "autoupdate": true,
  "mcp": {
    "tanstack": {
      "type": "local",
      "command": ["bunx", "@tanstack/cli", "mcp"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["bunx", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
